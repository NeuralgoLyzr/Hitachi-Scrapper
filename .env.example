# Copy to `.env` and fill in values. All keys below are required.

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=contact_enrich

# JWT
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# Lyzr
LYZR_API_KEY=
LYZR_USER_ID=
LYZR_INDUSTRY_CLASSIFICATION_AGENT_ID=
LYZR_AGENT_RESEARCH_DOMAIN_ID=
LYZR_INFERENCE_URL=https://agent-prod.studio.lyzr.ai/v3/inference/chat/
LYZR_BATCH_CONCURRENCY=3
LYZR_HTTP_TIMEOUT_SECONDS=180
LYZR_HTTP_RETRIES=3
LYZR_HTTP_RETRY_BACKOFF_SECONDS=5.0

# Apollo
APOLLO_API_KEY=
APOLLO_BASE_URL=https://api.apollo.io/v1

# Comma-separated browser origins for CORS
CORS_ORIGINS=http://localhost:3333
